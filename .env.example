# Database (required for core-api)
DATABASE_URL="postgresql://schoolos:schoolos_secret@localhost:5432/schoolos"

# JWT (optional; defaults shown)
JWT_SECRET=schoolos-demo-secret-change-in-production
JWT_EXPIRES=7d

# CORS (optional)
# Comma-separated origins for separately hosted frontends.
# Example:
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002,https://admin.schoolos.example.com,https://student.schoolos.example.com,https://parent.schoolos.example.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002

# LM Studio - local AI (optional; if not set, mock is used)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_KEY=lm-studio

# Integration API key for /api/integrations/careerbuddy/student-context
# INTEGRATION_API_KEY=your-secret-key
