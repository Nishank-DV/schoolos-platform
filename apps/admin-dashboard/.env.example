# For local dev, leave empty to use Vite proxy (/api -> http://127.0.0.1:4000)
VITE_API_URL=

# Optional: override the Vite dev proxy target if your API runs on a different host/port.
# VITE_API_PROXY_TARGET=http://127.0.0.1:4000

# For separately hosted production portal, set full API origin (no trailing slash)
# VITE_API_URL=https://api.schoolos.example.com

# Optional override for native mobile (Capacitor) builds.
# If set, this is preferred over VITE_API_URL on native runtime.
# VITE_MOBILE_API_URL=https://api.schoolos.example.com
